rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    function isPendingSigner() {
      return request.auth != null
        && resource.data.pendingSignerEmail != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() == resource.data.pendingSignerEmail;
    }

    match /documents/{documentId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;
      allow get: if isOwner() || isPendingSigner();
      allow list: if isOwner();
      allow update: if isOwner()
        || (isPendingSigner()
            && request.resource.data.ownerId == resource.data.ownerId
            && request.resource.data.pendingSignerEmail == resource.data.pendingSignerEmail);
      allow delete: if isOwner();
    }

    match /signingRequests/{token} {
      function isSender() {
        return request.auth != null && request.auth.uid == resource.data.senderId;
      }
      function isRecipient() {
        return request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email.lower() == resource.data.recipientEmail;
      }
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.senderId;
      allow get: if isSender() || isRecipient();
      allow list: if isSender();
      allow update: if isSender() || isRecipient();
      allow delete: if isSender();
    }

    match /envelopes/{envelopeId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.senderId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.senderId;
    }

    match /customTemplates/{templateId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;
    }

    match /projectFolders/{projectId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;
    }

    match /savedContacts/{contactId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;
    }

    match /sendPresets/{presetId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;
    }

    match /workspaceActivity/{activityId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if false;
    }

    match /billing/{userId} {
      // Users may read their own billing record. All writes (plan changes,
      // quota increments, Stripe sync) happen server-side via the Admin SDK,
      // which bypasses these rules, so clients are never allowed to write.
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /teams/{teamId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberIds;
      allow write: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
    }

    match /webhookSubscriptions/{subId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    match /apiKeys/{keyId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create, update, delete: if false;
    }

    match /signatures/{signatureId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    match /rateLimits/{limitId} {
      allow read, write: if false;
    }

    match /webhookOutbox/{jobId} {
      allow read, write: if false;
    }
  }
}
